# PostgreSQL connection
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=budgit
DATABASE_SSL_MODE=prefer

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_COOKIE_DOMAIN=localhost

# Stripe
STRIPE_LIVE_API_SECRET_KEY=sk_live_...
STRIPE_CUSTOMER_ID=cus_...
STRIPE_CUSTOMER_EMAIL=you@example.com
STRIPE_CUSTOMER_NAME=Your Name

# Venmo
VENMO_ACCESS_TOKEN=your_venmo_access_token

# Splitwise
SPLITWISE_CONSUMER_KEY=your_splitwise_consumer_key
SPLITWISE_CONSUMER_SECRET=your_splitwise_consumer_secret
SPLITWISE_API_KEY=your_splitwise_api_key

# Refresh cron protection
SCHEDULED_REFRESH_SECRET=change-me-strong-random-secret

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://dev.localhost:5173

# Logging
LOG_LEVEL=INFO
